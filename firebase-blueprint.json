{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "plan": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "createdAt"]
    },
    "Folder": {
      "title": "Folder",
      "description": "Folder metadata",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "createdAt"]
    },
    "File": {
      "title": "File",
      "description": "File metadata",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "folderId": { "type": "string" },
        "size": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "size", "createdAt"]
    },
    "Note": {
      "title": "Note",
      "description": "User note",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "createdAt"]
    },
    "TeamMember": {
      "title": "TeamMember",
      "description": "Team member information",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "role": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "createdAt"]
    },
    "Goal": {
      "title": "Goal",
      "description": "User goal tracking",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "targetValue": { "type": "number" },
        "currentValue": { "type": "number" },
        "unit": { "type": "string" },
        "deadline": { "type": "string", "format": "date" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "targetValue", "currentValue", "createdAt"]
    },
    "Habit": {
      "title": "Habit",
      "description": "User habit definition",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "frequency": { "type": "string", "enum": ["daily", "weekly"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "frequency", "createdAt"]
    },
    "HabitLog": {
      "title": "HabitLog",
      "description": "User habit completion log",
      "type": "object",
      "properties": {
        "habitId": { "type": "string" },
        "completed": { "type": "boolean" },
        "date": { "type": "string", "format": "date" }
      },
      "required": ["habitId", "completed", "date"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profile document"
    },
    "/users/{uid}/folders/{folderId}": {
      "schema": "Folder",
      "description": "User folders"
    },
    "/users/{uid}/files/{fileId}": {
      "schema": "File",
      "description": "User files"
    },
    "/users/{uid}/notes/{noteId}": {
      "schema": "Note",
      "description": "User notes"
    },
    "/users/{uid}/teamMembers/{memberId}": {
      "schema": "TeamMember",
      "description": "User team members"
    },
    "/users/{uid}/goals/{goalId}": {
      "schema": "Goal",
      "description": "User goals"
    },
    "/users/{uid}/habits/{habitId}": {
      "schema": "Habit",
      "description": "User habits"
    },
    "/users/{uid}/habitLogs/{logId}": {
      "schema": "HabitLog",
      "description": "User habit logs"
    }
  }
}
